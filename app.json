{
  "expo": {
    "name": "Eli Bridge",
    "slug": "eli-bridge",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "elibridge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "package": "dev.amburgey.elibridge",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "ios": {
      "bundleIdentifier": "dev.amburgey.elibridge",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
