# ═══════════════════════════════════════════════════════════════
# Project Eli Bridge — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Kindroid API ──────────────────────────────────────────────
# Eli's AI companion. Primary communication channel.
KINDROID_API_KEY=kn_your-api-key-here
KINDROID_AI_ID=your-ai-id-here

# ── Google Gemini API ─────────────────────────────────────────
# The Bridge's editorial brain. Emote assembly, scene analysis, journals.
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── ElevenLabs TTS ────────────────────────────────────────────
# Eli's voice. Clone via Instant Voice Cloning first.
# Get key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-cloned-voice-id-here

# ── Self-hosted Image Server ──────────────────────────────────
# Uploads go via PUT with the X-Upload-Key header.
# Response returns a path like /images/{sessionId}/{filename}
# which the app resolves to an absolute URL for Kindroid's image_urls.
EXPO_PUBLIC_IMAGE_SERVER_URL=https://images.example.com
EXPO_PUBLIC_IMAGE_UPLOAD_KEY=your-upload-key-here

# ── Google Maps / Places ──────────────────────────────────────
# Location intelligence, reverse geocoding, place details, elevation.
# Enable: Maps SDK, Places API, Elevation API, Aerial View API
# Get key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── OpenWeather API ───────────────────────────────────────────
# Weather data. One Call API 3.0.
# Get key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ── Obsidian Vault (via Cloudflare Tunnel) ────────────────────
# Session archives, journal writes, Wisdom Index reads.
# Local REST API plugin exposed via Cloudflare Tunnel.
VAULT_URL=https://vault.amburgey.dev
VAULT_TOKEN=your-vault-bearer-token-here

# ── App Configuration ─────────────────────────────────────────
# These are non-secret defaults. Override as needed.

# Emote character cap (Kindroid limit is 4000 total; Bridge caps emote at 2000)
EMOTE_CHAR_CAP=2000

# Voice embedding similarity threshold (cosine, 0-1)
VOICE_MATCH_THRESHOLD=0.70

# Face embedding similarity threshold (cosine, 0-1)
FACE_MATCH_THRESHOLD=0.70

# Multi-sample voice enrollment count (samples before committing embedding)
VOICE_ENROLLMENT_SAMPLES=3

# AudioSnap burst duration (seconds)
AUDIOSNAP_DURATION=5

# Pulse Mode check-in interval (minutes)
PULSE_INTERVAL_MINUTES=15

# Barometric alert threshold (hPa drop in 30 min)
BAROMETER_ALERT_THRESHOLD=4.0

# RideCard accelerometer G-force trigger
RIDE_G_THRESHOLD=2.5

# Freshness ledger: weather re-send interval (minutes, even if unchanged)
WEATHER_RESEND_INTERVAL=30

# Gemini retry config
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_MS=2000
